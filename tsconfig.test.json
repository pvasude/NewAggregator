{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["prisma/__tests__/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
